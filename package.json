{
  "name": "pointage-hopital-senegal",
  "version": "1.0.0",
  "description": "Application desktop Electron de gestion de pointage hospitalier adaptee au systeme sanitaire senegalais.",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron-ts,electron \"vite --host 127.0.0.1\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 dist-electron/electron/main.js && electron .\"",
    "build": "tsc --noEmit && tsc -p tsconfig.electron.json && vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "start": "electron .",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dakarecho/cursor_presence.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "sn.sante.pointage-hopital",
    "productName": "Pointage Hopital Senegal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sqljs/sql-wasm.wasm"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "bugs": {
    "url": "https://github.com/dakarecho/cursor_presence/issues"
  },
  "homepage": "https://github.com/dakarecho/cursor_presence#readme",
  "dependencies": {
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  }
}
